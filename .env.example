APP_NAME="Aleph∞One"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

FLARE_KEY=
FLARE_TRACE=false
FLARE_TRACE_SAMPLE_RATE=0.1

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# SQLite journal: default WAL/NORMAL (best for a concurrent web app on local disk).
# Override to DELETE/FULL in local dev if a GUI client (e.g. TablePlus) opens the
# same file, to avoid sidecar -wal/-shm contention.
# DB_JOURNAL_MODE=WAL
# DB_SYNCHRONOUS=NORMAL

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# For non-AWS S3-compatible buckets (Backblaze B2, MinIO, Cloudflare R2, ...)
# AWS_ENDPOINT=
# AWS_URL=

# Database backups (spatie/laravel-backup) — destination is a filesystem disk.
# Set BACKUP_DISK=s3 and fill the AWS_* bucket credentials above.
BACKUP_DISK=s3
BACKUP_NOTIFICATION_EMAIL=
# Encrypt the backup archive at rest (recommended — the DB contains PII).
BACKUP_ARCHIVE_PASSWORD=

VITE_APP_NAME="${APP_NAME}"

# WebAuthn / passkeys. WEBAUTHN_ID = domain without scheme (e.g. app.aleph-one.com),
# WEBAUTHN_ORIGINS = full origin URL. Leave blank to derive from the request host.
WEBAUTHN_NAME="${APP_NAME}"
WEBAUTHN_ID=
WEBAUTHN_ORIGINS=

# Legal documents (Terms of Service, Privacy Policy). Hosted outside this app.
# When both URLs are blank the legal links and the registration consent checkbox
# are hidden and acceptance is not required. Bump the *_VERSION values whenever the
# published documents change so recorded acceptances stay auditable.
LEGAL_TERMS_URL=
LEGAL_PRIVACY_URL=
LEGAL_TERMS_VERSION=
LEGAL_PRIVACY_VERSION=
